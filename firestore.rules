rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validations
    function isValidLead(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 150
        && data.phone is string && data.phone.size() <= 30
        && data.email is string && data.email.size() <= 150
        && data.businessName is string && data.businessName.size() <= 200
        && data.status is string && data.status.size() <= 50
        && data.assignedTo is string && data.assignedTo.size() <= 100;
    }

    function isValidTeamMember(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 150
        && data.role is string && data.role.size() <= 100
        && data.avatarColor is string && data.avatarColor.size() <= 100
        && data.leadsAssigned is number
        && data.dealsClosed is number
        && data.revenueGenerated is number
        && data.activeRate is number;
    }

    function isValidRecurringTask(data) {
      return data.id is string && data.id.size() <= 128
        && data.memberName is string && data.memberName.size() <= 150
        && data.title is string && data.title.size() <= 300
        && data.frequency is string && data.frequency.size() <= 50;
    }

    // Leads Match Blocks
    match /leads/{leadId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isEmailVerified() && isValidId(leadId) && isValidLead(incoming()) && incoming().id == leadId;
      allow update: if isEmailVerified() && isValidId(leadId) && isValidLead(incoming()) && incoming().id == leadId;
      allow delete: if isEmailVerified() && isValidId(leadId);
    }

    // Team Match Blocks
    match /team/{memberId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isEmailVerified() && isValidId(memberId) && isValidTeamMember(incoming()) && incoming().id == memberId;
      allow update: if isEmailVerified() && isValidId(memberId) && isValidTeamMember(incoming()) && incoming().id == memberId;
      allow delete: if isEmailVerified() && isValidId(memberId);
    }

    // Recurring Tasks Match Blocks
    match /recurring_tasks/{taskId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isEmailVerified() && isValidId(taskId) && isValidRecurringTask(incoming()) && incoming().id == taskId;
      allow update: if isEmailVerified() && isValidId(taskId) && isValidRecurringTask(incoming()) && incoming().id == taskId;
      allow delete: if isEmailVerified() && isValidId(taskId);
    }
  }
}
